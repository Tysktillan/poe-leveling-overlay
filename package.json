{
  "name": "poe-leveling-overlay",
  "version": "1.0.0",
  "description": "A transparent in-game overlay for Path of Exile that guides you through leveling with zone-by-zone tasks, skill gem links from Path of Building, and a passive skill tree tracker.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "keywords": [
    "path-of-exile",
    "poe",
    "overlay",
    "leveling",
    "guide"
  ],
  "author": "jtill",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "koffi": "^2.15.1",
    "tail": "^2.2.6",
    "tail-file": "^1.4.16"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.poe-leveling-overlay",
    "productName": "PoE Leveling Overlay",
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "PoE-Leveling-Overlay.exe"
    },
    "files": [
      "main.js",
      "index.html",
      "notes.html",
      "tree.html",
      "treeRenderer.js",
      "poe_tree.json",
      "route.json",
      "zone-guide.json",
      "quest-gem-rewards.json",
      "package.json",
      "build/icon.ico"
    ],
    "extraResources": []
  }
}
