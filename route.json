{
  "leveling_regex": [
    {
      "name": "2H Melee (RRG + MS boots)",
      "regex": "-\\w-.-|r-r-|-r-r|r-.-r|g-g-|-g-g|g-.-g|Runn|rint"
    },
    {
      "name": "Caster (BBB + MS boots)",
      "regex": "-\\w-.-|b-b-|-b-b|b-.-b|Runn|rint"
    },
    {
      "name": "Bow / Dex (GGG + MS boots)",
      "regex": "-\\w-.-|g-g-|-g-g|g-.-g|Runn|rint"
    },
    {
      "name": "Spellcaster (BBG + MS boots)",
      "regex": "-\\w-.-|b-b-|-b-b|b-.-b|g-g-|-g-g|g-.-g|Runn|rint"
    },
    {
      "name": "Chromatic Recipe (RGB linked)",
      "regex": ":.*(?=\\S*r)(?=\\S*g)(?=\\S*b)"
    },
    {
      "name": "+1 Spell Wand (vendor)",
      "regex": "ll g"
    },
    {
      "name": "Templar Early (2B/RB/RR + RG + MS + +1 Wand)",
      "regex": ":.*(?=\\S*r)(?=\\S*g)(?=\\S*b)|r-r|b-b|g-r|r-g|Runn|ll g"
    },
    {
      "name": "Caster Mid (BBB + 4L + RGB + MS + +1 Wand)",
      "regex": "-\\w-.-|b-b-b|:.*(?=\\S*r)(?=\\S*g)(?=\\S*b)|Runn|rint|ll g"
    }
  ],
